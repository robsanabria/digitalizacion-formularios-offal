# ===========================================================================
# Control de Etiquetas — variables de entorno
# Copiar este archivo como ".env" y completar los valores.
# ===========================================================================

# ── Base de datos (SQL Server local o Azure SQL) ──
DB_SERVER=localhost
DB_NAME=ControlEtiquetas
DB_USER=sa
DB_PASS=CambiarEstaClave1!
DB_PORT=1433
DB_ENCRYPT=false            # true para Azure SQL; false para SQL Server local

# ── Almacenamiento de imágenes/adjuntos (Azure Blob Storage) ──
# Sin esto, la app funciona pero NO se pueden subir/ver adjuntos.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=regsis-attachments

# ── Aplicación ──
PORT=3001
NODE_ENV=development        # 'development' habilita el usuario local sin login de Azure
DEV_USER_ROLE=ADMIN         # Rol del usuario local en desarrollo: ADMIN | CALIDAD | SISTEMAS

# ── Solo producción (Azure EasyAuth) ──
DEFAULT_USER_ROLE=CALIDAD   # Rol por defecto de usuarios nuevos autenticados
ADMIN_EMAILS=               # emails de admin separados por coma
PRINT_SECRET=               # (legacy — ya no se usa para PDF)
